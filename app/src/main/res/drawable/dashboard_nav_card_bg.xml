<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="@color/white_08">

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/dashboard_radius" />
            <gradient
                android:angle="270"
                android:startColor="@color/dashboard_surface_2"
                android:endColor="@color/dashboard_surface" />
            <stroke
                android:width="1dp"
                android:color="@color/dashboard_border" />
        </shape>
    </item>

</ripple>