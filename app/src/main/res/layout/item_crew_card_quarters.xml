<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/space_12"
    android:background="@drawable/dashboard_panel_bg"
    android:gravity="center_vertical"
    android:minHeight="118dp"
    android:orientation="horizontal"
    android:padding="14dp">

    <FrameLayout
        android:layout_width="74dp"
        android:layout_height="74dp"
        android:background="@drawable/dashboard_avatar_frame_bg"
        android:padding="2dp">

        <ImageView
            android:id="@+id/ivCrewPortrait"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:adjustViewBounds="true"
            android:scaleType="centerCrop" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvCrewName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:text="NOVA"
            android:textColor="@color/dashboard_text_primary"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/tvCrewRole"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.08"
            android:text="ROLE: PILOT"
            android:textAllCaps="true"
            android:textColor="@color/dashboard_text_secondary"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/tvCrewStats"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="sans-serif-medium"
            android:text="LVL 1   HP 20/20   EXP 0"
            android:textColor="@color/dashboard_text_primary"
            android:textSize="13sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="112dp"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvCrewStatus"
            android:layout_width="96dp"
            android:layout_height="38dp"
            android:background="@drawable/dashboard_chip_bg"
            android:fontFamily="sans-serif-black"
            android:gravity="center"
            android:includeFontPadding="false"
            android:text="QUARTERS"
            android:textAllCaps="true"
            android:textColor="@color/dashboard_text_primary"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/btnRemoveCrew"
            android:layout_width="96dp"
            android:layout_height="38dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/dashboard_delete_bg"
            android:clickable="true"
            android:focusable="true"
            android:fontFamily="sans-serif-black"
            android:gravity="center"
            android:includeFontPadding="false"
            android:text="DELETE"
            android:textAllCaps="true"
            android:textColor="@color/dashboard_text_primary"
            android:textSize="10sp" />
    </LinearLayout>

</LinearLayout>