<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="8dp"
        android:paddingEnd="16dp"
        android:paddingBottom="24dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="horizontal">

                <!-- HELP BUTTON -->
                <Button
                    android:id="@+id/btnShowHelp"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginEnd="8dp"
                    android:backgroundTint="@color/dashboard_cyan"
                    android:fontFamily="sans-serif-black"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:text="HELP"
                    android:textColor="@android:color/white"
                    android:textSize="12sp"
                    app:cornerRadius="20dp" />

                <!-- HIGHLY VISIBLE RESET BUTTON -->
                <Button
                    android:id="@+id/btnResetGame"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginEnd="12dp"
                    android:backgroundTint="@color/dashboard_red"
                    android:fontFamily="sans-serif-black"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:text="RESET"
                    android:textColor="@android:color/white"
                    android:textSize="12sp"
                    app:cornerRadius="20dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvCoins"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/dashboard_coin_pill_bg"
                android:fontFamily="sans-serif-black"
                android:paddingStart="18dp"
                android:paddingTop="10dp"
                android:paddingEnd="18dp"
                android:paddingBottom="10dp"
                android:text="300 COINS"
                android:textAllCaps="true"
                android:textColor="@color/dashboard_amber"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Top stats -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:background="@drawable/dashboard_stat_bg"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingTop="12dp"
                android:paddingEnd="16dp"
                android:paddingBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.10"
                    android:text="MISSIONS"
                    android:textAllCaps="true"
                    android:textColor="@color/dashboard_text_secondary"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/tvMissionCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="sans-serif-black"
                    android:text="0"
                    android:textColor="@color/dashboard_text_primary"
                    android:textSize="28sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/dashboard_stat_bg"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingTop="12dp"
                android:paddingEnd="16dp"
                android:paddingBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.10"
                    android:text="TOTAL CREW"
                    android:textAllCaps="true"
                    android:textColor="@color/dashboard_text_secondary"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/tvTotalCrewCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="sans-serif-black"
                    android:text="1"
                    android:textColor="@color/dashboard_text_primary"
                    android:textSize="28sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Mission performance -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/dashboard_panel_bg"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="12dp"
            android:paddingEnd="16dp"
            android:paddingBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.10"
                android:text="MISSION PERFORMANCE"
                android:textAllCaps="true"
                android:textColor="@color/dashboard_text_secondary"
                android:textSize="12sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Wins"
                        android:textColor="@color/dashboard_text_muted"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tvWins"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="sans-serif-black"
                        android:text="0"
                        android:textColor="@color/dashboard_text_primary"
                        android:textSize="22sp" />
                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="@color/dashboard_divider" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:orientation="vertical"
                    android:paddingStart="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Losses"
                        android:textColor="@color/dashboard_text_muted"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tvLosses"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="sans-serif-black"
                        android:text="0"
                        android:textColor="@color/dashboard_text_primary"
                        android:textSize="22sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Crew header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:fontFamily="sans-serif-black"
            android:text="CREW"
            android:textColor="@color/dashboard_text_primary"
            android:textSize="18sp" />

        <!-- Crew list -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvCrew"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:clipToPadding="false"
            android:nestedScrollingEnabled="false"
            android:overScrollMode="never" />

        <!-- Navigation header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:fontFamily="sans-serif-black"
            android:text="NAVIGATION"
            android:textColor="@color/dashboard_text_primary"
            android:textSize="18sp" />

        <!-- Row 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/navHospital"
                android:layout_width="0dp"
                android:layout_height="84dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:background="@drawable/dashboard_nav_card_bg"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:fontFamily="sans-serif-black"
                    android:text="HOSPITAL"
                    android:textAlignment="center"
                    android:textColor="@color/dashboard_text_primary"
                    android:textSize="16sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navWorkshop"
                android:layout_width="0dp"
                android:layout_height="84dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/dashboard_nav_card_bg"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:fontFamily="sans-serif-black"
                    android:text="WORKSHOP"
                    android:textColor="@color/dashboard_text_primary"
                    android:textSize="16sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Row 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/navMission"
                android:layout_width="0dp"
                android:layout_height="84dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:background="@drawable/dashboard_nav_card_bg"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:fontFamily="sans-serif-black"
                    android:text="MISSION"
                    android:textColor="@color/dashboard_text_primary"
                    android:textSize="16sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navTraining"
                android:layout_width="0dp"
                android:layout_height="84dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/dashboard_nav_card_bg"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:fontFamily="sans-serif-black"
                    android:text="TRAINING"
                    android:textColor="@color/dashboard_text_primary"
                    android:textSize="16sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Row 3 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/navLunaris"
                android:layout_width="0dp"
                android:layout_height="84dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:background="@drawable/dashboard_nav_card_bg"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:fontFamily="sans-serif-black"
                    android:text="LUNARIS"
                    android:textColor="@color/dashboard_text_primary"
                    android:textSize="16sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navAethra"
                android:layout_width="0dp"
                android:layout_height="84dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/dashboard_nav_card_bg"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:fontFamily="sans-serif-black"
                    android:text="AETHRA"
                    android:textColor="@color/dashboard_text_primary"
                    android:textSize="16sp" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>