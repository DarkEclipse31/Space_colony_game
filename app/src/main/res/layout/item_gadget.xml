<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:background="@drawable/stat_card_bg"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="10dp">

    <ImageView
        android:id="@+id/ivGadgetImage"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:scaleType="centerCrop"
        android:src="@drawable/medicine" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvGadgetName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Medicine"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvGadgetType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Type: MEDICINE"
            android:textColor="#BFE8FF"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/tvGadgetValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Healing: +15"
            android:textColor="#BFE8FF"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/tvUsesLeft"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Uses: 1"
            android:textColor="#FFD54F"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <Button
        android:id="@+id/btnUse"
        android:layout_width="72dp"
        android:layout_height="36dp"
        android:background="@drawable/btn_dragon_bg"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:padding="0dp"
        android:text="SELECT"
        android:textAllCaps="true"
        android:textColor="#FFFFFF"
        android:textSize="10sp"
        android:textStyle="bold" />
</LinearLayout>