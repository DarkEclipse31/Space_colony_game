<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/btnBackMissionControl"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/dashboard_delete_bg"
            android:clickable="true"
            android:focusable="true"
            android:fontFamily="sans-serif-black"
            android:paddingStart="18dp"
            android:paddingTop="10dp"
            android:paddingEnd="18dp"
            android:paddingBottom="10dp"
            android:text="&lt; Mission Control"
            android:textColor="@color/dashboard_text_primary"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/dashboard_panel_bg"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvMissionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:text="MISSION TITLE"
                android:textColor="@color/dashboard_text_primary"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/tvMissionMeta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Difficulty: Medium | Category: Combat"
                android:textColor="@color/dashboard_text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvMissionThreat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Threat HP: 30 | Attack: 8 | Retaliate: 2"
                android:textColor="@color/dashboard_text_primary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvMissionCrewLimit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Allowed Crew: 1 to 3"
                android:textColor="@color/dashboard_amber"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvSelectedCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Selected: 0 / 3"
                android:textColor="@color/dashboard_text_primary"
                android:textSize="13sp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:fontFamily="sans-serif-black"
            android:text="SELECT CREW"
            android:textColor="@android:color/white"
            android:textSize="22sp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvSelectableCrew"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:nestedScrollingEnabled="false"
            android:overScrollMode="never" />

        <TextView
            android:id="@+id/btnStartMission"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/dashboard_delete_bg"
            android:clickable="true"
            android:focusable="true"
            android:fontFamily="sans-serif-black"
            android:gravity="center"
            android:text="START MISSION"
            android:textAllCaps="true"
            android:textColor="@android:color/white"
            android:textSize="14sp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>