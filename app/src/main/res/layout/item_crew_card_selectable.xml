<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/dashboard_panel_bg"
    android:gravity="center_vertical"
    android:minHeight="96dp"
    android:orientation="horizontal"
    android:padding="12dp">

    <FrameLayout
        android:layout_width="62dp"
        android:layout_height="62dp"
        android:background="@drawable/dashboard_avatar_frame_bg"
        android:padding="2dp">

        <ImageView
            android:id="@+id/ivCrewPortraitSelect"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvCrewNameSelect"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:text="NOVA"
            android:textColor="@color/dashboard_text_primary"
            android:textSize="17sp" />

        <TextView
            android:id="@+id/tvCrewRoleSelect"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="ROLE: PILOT"
            android:textColor="@color/dashboard_text_secondary"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/tvCrewStatsSelect"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="LVL 1   HP 20/20"
            android:textColor="@color/dashboard_text_primary"
            android:textSize="12sp" />
    </LinearLayout>

    <CheckBox
        android:id="@+id/cbSelectCrew"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:buttonTint="@color/dashboard_amber" />
</LinearLayout>