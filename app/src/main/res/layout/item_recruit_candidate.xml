<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/stat_card_bg"
    android:orientation="horizontal"
    android:padding="12dp">

    <ImageView
        android:id="@+id/ivRecruitProfile"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:scaleType="centerCrop"
        android:src="@drawable/pilot_1" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvRecruitName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nova"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvRecruitRole"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="ROLE: PILOT"
            android:textColor="#CFCFCF"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvRecruitStats"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="LVL 3 | HP 24 | ATTACK 7 | RESILIENCE 5"
            android:textColor="#BFE8FF"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvRecruitCost"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="200 COINS"
            android:textColor="#FFD54F"
            android:textSize="12sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnAddCrew"
            android:layout_width="100dp"
            android:layout_height="38dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/btn_dragon_bg"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="0dp"
            android:text="ADD CREW"
            android:textAllCaps="true"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>