<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/lab" />

    <Button
        android:id="@+id/btnBackFromWorkshop"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:layout_gravity="top|start"
        android:layout_margin="14dp"
        android:background="@drawable/dashboard_nav_card_bg"
        android:text="&lt; Quarters"
        android:textColor="#FFFFFF" />

    <TextView
        android:id="@+id/tvWorkshopCoins"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_margin="14dp"
        android:background="@drawable/dashboard_coin_pill_bg"
        android:paddingHorizontal="14dp"
        android:paddingVertical="8dp"
        android:text="150 COINS"
        android:textColor="#FFD54F"
        android:textStyle="bold" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="60dp"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ENGINEERING WORKSHOP"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:fontFamily="sans-serif-black"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvWorkshopInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/dashboard_panel_bg"
                android:padding="12dp"
                android:text="Workshop info"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/dashboard_stat_bg"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="12dp">

                <Button
                    android:id="@+id/btnPrevScientist"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@android:color/transparent"
                    android:text="&lt;"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp" />

                <TextView
                    android:id="@+id/tvWorkshopSelectedScientist"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="10dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Scientist info"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnNextScientist"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@android:color/transparent"
                    android:text="&gt;"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/dashboard_panel_bg"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:padding="16dp">

                <ImageView
                    android:id="@+id/ivWorkshopPreview"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/medicine" />

                <TextView
                    android:id="@+id/tvWorkshopSelectedGadget"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Gadget info"
                    android:textColor="#FFD54F"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnGadgetMedicine"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:background="@drawable/btn_dragon_bg"
                        android:text="Medicine"
                        android:textSize="11sp" />

                    <Button
                        android:id="@+id/btnGadgetRifle"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/btn_dragon_bg"
                        android:text="Rifle"
                        android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnGadgetArmour"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:background="@drawable/btn_dragon_bg"
                        android:text="Armour"
                        android:textSize="11sp" />

                    <Button
                        android:id="@+id/btnGadgetPotion"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/btn_dragon_bg"
                        android:text="Potion"
                        android:textSize="11sp" />
                </LinearLayout>

                <Button
                    android:id="@+id/btnGenerateGadget"
                    android:layout_width="180dp"
                    android:layout_height="48dp"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/btn_dragon_bg"
                    android:text="CRAFT GADGET"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnRetrieveGadget"
                    android:layout_width="180dp"
                    android:layout_height="48dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/dashboard_nav_card_bg"
                    android:text="COLLECT"
                    android:textColor="#FFFFFF" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="ACTIVE PROJECTS"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvWorkshopNoJobs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/dashboard_stat_bg"
                android:padding="12dp"
                android:text="No active crafting jobs"
                android:textColor="#BFE8FF"
                android:textSize="12sp"
                android:lineSpacingExtra="4dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvWorkshopJobs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never"
                android:visibility="gone" />
        </LinearLayout>
    </ScrollView>
</FrameLayout>