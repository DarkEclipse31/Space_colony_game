<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/btnBackDragonSetup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/dashboard_delete_bg"
            android:clickable="true"
            android:focusable="true"
            android:fontFamily="sans-serif-black"
            android:paddingStart="18dp"
            android:paddingTop="10dp"
            android:paddingEnd="18dp"
            android:paddingBottom="10dp"
            android:text="&lt; Back to Aethra"
            android:textColor="@color/dashboard_text_primary"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/dashboard_panel_bg"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvDragonSetupTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:text="BOSS: DRAGON"
                android:textColor="@color/dashboard_text_primary"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/tvDragonMeta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Difficulty: ELITE | Category: BOSS FIGHT"
                android:textColor="@color/dashboard_text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvDragonThreat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Threat HP: 125 | Attack: 16 | Retaliate: 6"
                android:textColor="@color/dashboard_text_primary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvDragonCrewLimit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Allowed Crew: 1 to 6"
                android:textColor="@color/dashboard_amber"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvDragonSelectedCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Selected: 0 / 6"
                android:textColor="@color/dashboard_text_primary"
                android:textSize="13sp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:fontFamily="sans-serif-black"
            android:text="CHOOSE FINAL SQUAD"
            android:textColor="@android:color/white"
            android:textSize="22sp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvDragonSelectableCrew"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:nestedScrollingEnabled="false"
            android:overScrollMode="never" />

        <TextView
            android:id="@+id/btnStartDragonBattle"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/dashboard_delete_bg"
            android:clickable="true"
            android:focusable="true"
            android:fontFamily="sans-serif-black"
            android:gravity="center"
            android:text="START DRAGON FIGHT"
            android:textAllCaps="true"
            android:textColor="@android:color/white"
            android:textSize="14sp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>